{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "brainerd/feature-grid",
  "title": "Feature Grid",
  "description": "A responsive grid of feature cards (icon/title/text).",
  "category": "brainerd",
  "icon": "grid-view",
  "keywords": ["features", "grid", "cards"],
  "acf": {
    "mode": "auto",
